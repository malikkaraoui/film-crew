DATABASE_URL=postgresql://malik@localhost:5432/video_tiktok

# Providers — ajouter les clés au fur et à mesure
# SEEDANCE_API_KEY=
# FISH_AUDIO_API_KEY=
# OLLAMA_URL=http://localhost:11434
# PEXELS_API_KEY=
# PIXABAY_API_KEY=

# TikTok publishing / OAuth (10A)
# Après déploiement HTTPS (ex: Vercel), enregistrer :
#   https://<ton-app>.vercel.app/tiktok/callback
# Puis lancer le flow depuis /tiktok/connect
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=
# TIKTOK_ACCESS_TOKEN=
# TIKTOK_REFRESH_TOKEN=

# TTS — priorité configurable (lot 9A)
# Ordre de résolution : le 1er provider disponible est utilisé
# TTS_PRIORITY=kokoro-local,piper-local,fish-audio
# TTS_DISABLED=fish-audio   # désactiver un ou plusieurs providers (virgule)

# Kokoro local (primaire) — lancer : docker run -p 8880:8880 ghcr.io/remsky/kokoro-fastapi-cpu:v0.2.2
# KOKORO_URL=http://localhost:8880
# KOKORO_VOICE=af_heart

# Piper local (fallback) — installer : brew install piper-tts / apt install piper
# PIPER_BINARY=/usr/local/bin/piper
# PIPER_MODEL=/path/to/fr_FR-upmc-medium.onnx
