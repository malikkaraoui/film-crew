DATABASE_URL=postgresql://malik@localhost:5432/video_tiktok

# Providers — ajouter les clés au fur et à mesure
# SEEDANCE_API_KEY=
# FISH_AUDIO_API_KEY=
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_STORYBOARD_CLOUD_ENABLED=1
# OLLAMA_STORYBOARD_CLOUD_MODEL=gemma4:31b-cloud
# OLLAMA_CLOUD_URL=https://ollama.com
# OLLAMA_API_KEY=
# PEXELS_API_KEY=
# PIXABAY_API_KEY=

# Storyboard cloud Ollama
# - Si OLLAMA_API_KEY est renseignee, l'app parle directement a https://ollama.com/api
# - Sinon, l'app passe par ton Ollama local (OLLAMA_URL), utile si tu es deja connecte avec `ollama signin`
# - Le rendu image final reste local pour l'etape 5 (Storyboard) ; le cloud sert a generer un plan JSON plus intelligent en parallele

# TikTok publishing / OAuth (10A)
# Après déploiement HTTPS (ex: Vercel), enregistrer :
#   https://<ton-app>.vercel.app/tiktok/callback
# Puis lancer le flow depuis /tiktok/connect
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=
# TIKTOK_ACCESS_TOKEN=
# TIKTOK_REFRESH_TOKEN=
# TIKTOK_PROFILE_HANDLE=ton_handle_sans_arobase

# YouTube Shorts publishing (11B)
# Obtenir via OAuth Playground : https://developers.google.com/oauthplayground
# Scope requis : https://www.googleapis.com/auth/youtube.upload
# YOUTUBE_ACCESS_TOKEN=
# YOUTUBE_CHANNEL_ID=ton_channel_id  (optionnel, pour le profileUrl)

# TTS — priorité configurable (lot 9A)
# Ordre de résolution : le 1er provider disponible est utilisé
# TTS_PRIORITY=kokoro-local,piper-local,fish-audio
# TTS_DISABLED=fish-audio   # désactiver un ou plusieurs providers (virgule)

# Kokoro local (primaire) — lancer : docker run -p 8880:8880 ghcr.io/remsky/kokoro-fastapi-cpu:v0.2.2
# KOKORO_URL=http://localhost:8880
# KOKORO_VOICE=ff_siwis

# Piper local (fallback) — installer : brew install piper-tts / apt install piper
# PIPER_BINARY=/usr/local/bin/piper
# PIPER_MODEL=/path/to/fr_FR-upmc-medium.onnx
